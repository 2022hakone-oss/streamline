<%= form_with(model: @blog, local: true) do |form| %>

  <div class="title">
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

    <div class="time">
    <%= form.label :start_time %>
    <%= form.datetime_select :start_time %>
  </div>
  
  <div class="content">
    <%= form.label :content %>
    <%= form.text_field :content %>
  </div>


  <div class="submit">
    <%= form.submit %>
  </div>

  
  <div class="field">
    <%= form.label :tag_list, "タグ（カンマ「,」区切りで複数入力可）" %>
    <%= form.text_field :tag_list, value: (@blog.tag_list.present? ? @blog.tag_list.join(', ') : nil), class: "form-control" %>
  </div>

<% end %>
