<header style="background-color: #1a1a1a; color: #fff; padding: 20px; margin-bottom: 30px;">
  <h1 style="margin: 0; font-family: 'Helvetica Neue', Arial, sans-serif; letter-spacing: 2px;">Streamline</h1>
  <p style="margin: 5px 0 0 0; color: #aaa; font-size: 0.9rem;">シンプルで、途切れない思考の記録</p>
</header>

<%= form_tag({controller:"posts",action:"index"}, method: :get) do %>
      <%= label_tag :tag_ids, "タグで絞り込む（複数選択可）" %><br>
      <% Tag.all.each do |t| %>
          <%= check_box_tag "tag_ids[]", t.id, params[:tag_ids]&.include?(t.id.to_s) %>
          <%= t.name %><br>
      <% end %>
      <%= submit_tag '検索' %>
<% end %>

<div style="max-width: 600px; margin: 0 auto; padding: 0 20px;">
  <%= link_to "+ 新しく思考をストリームする", new_post_path, style: "color: #007bff; text-decoration: none; font-weight: bold;" %>

  <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">

  <% @posts.each do |post| %>
    <div style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #f0f0f0;">
      
      <h2 style="margin: 0 0 10px 0; font-size: 1.5rem;">
        <%= link_to post.title, post_path(post), style: "color: #007bff; text-decoration: underline;" %>
      </h2>
      
      <p style="color: #555; line-height: 1.6; white-space: pre-wrap;"><%= post.body %></p>
      <small style="color: #999;"><%= post.created_at.strftime("%Y-%m-%d %H:%M") %></small>
    </div>
  <% end %>
</div>
